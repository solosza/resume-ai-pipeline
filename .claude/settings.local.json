{
  "permissions": {
    "allow": [
      "Skill(kernel:session-start)",
      "Skill(kernel:anchor)",
      "Skill(kernel:validate)",
      "Bash(npm install)",
      "Bash(npx playwright install chromium)",
      "Bash(npx tsc:*)",
      "Bash(npm install:*)",
      "Skill(kernel:learn)",
      "Bash(npm test:*)",
      "Skill(kernel:fix)",
      "WebFetch(domain:reqres.in)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/universal-gate-enforcer.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/playwright-gate-enforcer.py"
          }
        ]
      }
    ]
  }
}
